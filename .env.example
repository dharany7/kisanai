# ──────────────────────────────────────────────────────────────────────────────
# KisanAI — Environment Variable Reference
# Copy this file to .env before running the project:
#   Windows:        Copy-Item .env.example .env
#   macOS / Linux:  cp .env.example .env
# Then replace every placeholder value with your real credentials.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Twilio (WhatsApp messaging) ───────────────────────────────────────────────
# Found at: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# Your Twilio WhatsApp sandbox number (always this for sandbox)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── Plant.id (crop disease vision API) ───────────────────────────────────────
# Sign up at: https://web.plant.id/ → API Keys
PLANT_ID_API_KEY=your_plant_id_api_key_here

# ── Google Gemini (LLM for advisory generation) ───────────────────────────────
# Found at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Ngrok (public tunnel URL for local development) ───────────────────────────
# Run: ngrok http 8000  → copy the https://xxxx.ngrok-free.app URL here
# Required for Twilio to fetch audio files from your local server
NGROK_BASE_URL=https://your-ngrok-url-here
